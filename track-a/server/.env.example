# 必填：服务鉴权，快捷指令需通过 X-API-Key 发送
KEEL_API_KEY=

# 必填：至少配置一个（中国大陆优先）
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# 可选：模型名（默认用便宜模型；仅 /max 或 depth: deep 才用贵模型）
DEEPSEEK_MODEL_DEFAULT=deepseek-chat
DEEPSEEK_MODEL_DEEP=deepseek-reasoner

# 可选：Qwen 仅作为 DeepSeek 不可用时的后备
QWEN_MODEL_DEFAULT=qwen-plus
QWEN_MODEL_MAX=qwen-max

# 可选：覆盖 API 地址（一般不用改）
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 可选：把某些 topic 固定为深度模式（逗号分隔 slug）
DEEP_TOPIC_SLUGS=deep,strategic,重大

# 可选：数据目录与人格文件路径
# TRACK_A_DATA_DIR=../data
# PERSONALITY_CHARTER_PATH=../../PERSONALITY_CHARTER.md
